<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/build_buddy_graph"
    app:startDestination="@id/buildBuddyLoadFragment">

    <fragment
        android:id="@+id/buildBuddyLoadFragment"
        android:name="com.buildsof.budsde.gort.presentation.ui.load.BuildBuddyLoadFragment"
        android:label="BuildBuddyLoadFragment" >
        <action
            android:id="@+id/action_buildBuddyLoadFragment_to_buildBuddyV"
            app:destination="@id/buildBuddyV"
            app:popUpTo="@id/build_buddy_graph"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/buildBuddyV"
        android:name="com.buildsof.budsde.gort.presentation.ui.view.BuildBuddyV"
        android:label="BuildBuddyV" />
</navigation>